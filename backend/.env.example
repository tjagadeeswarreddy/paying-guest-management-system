# Backend runtime config
PORT=8080
APP_DATA_PROVIDER=postgres

# Neon / PostgreSQL
DB_URL=jdbc:postgresql://<host>:5432/<db>?sslmode=require&channel_binding=require
DB_USERNAME=neondb_owner
DB_PASSWORD=replace_with_secure_password
# Optional aliases used by some platforms (Render/GCP/etc.)
# SPRING_DATASOURCE_URL=
# SPRING_DATASOURCE_USERNAME=
# SPRING_DATASOURCE_PASSWORD=

# Optional tuning
DB_POOL_MAX=10
DB_POOL_MIN=2
DDL_AUTO=update
HIBERNATE_FORMAT_SQL=false
FILE_STORAGE_PATH=uploads
APP_CACHE_PROVIDER=local
APP_CACHE_TTL_SECONDS=60
APP_CACHE_MAX_SIZE=500

# Redis (used when APP_CACHE_PROVIDER=redis)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TIMEOUT_MS=2000ms

# Firebase (used when APP_DATA_PROVIDER=firebase)
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=

# Comma separated frontend origins for CORS
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
